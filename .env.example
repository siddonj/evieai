# ─── Azure OpenAI (required) ─────────────────────────────────
# Paste values from: terraform output -raw openai_endpoint / openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-openai-name.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# LLM provider selection: azure-openai | obot-ai
LLM_PROVIDER=azure-openai

# ─── obot.ai (optional during migration) ─────────────────────
# Required when LLM_PROVIDER=obot-ai
OBOT_BASE_URL=
OBOT_API_KEY=
OBOT_MODEL=gpt-4o
# Set false only for trusted/self-hosted obot endpoints that do not require API auth.
OBOT_API_REQUIRED=true

# ─── Azure Deployment (required for service restart functionality) ────
# These are used by the admin dashboard to restart Container Apps services.
# Usually set automatically by terraform, but can be overridden here.
PROJECT_NAME=aiagent2
ENVIRONMENT=dev
RESOURCE_GROUP=rg-aiagent2-dev
# Subscription ID for Azure SDK restart functionality (optional if using az CLI)
AZURE_SUBSCRIPTION_ID=

# ─── Database (local dev defaults are fine) ──────────────────
DB_PASSWORD=DevP@ssw0rd!
POSTGRES_DB=evieai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Used by postgresql-mcp service
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/evieai
POSTGRES_MAX_ROWS=200

# ─── Auth / Web UI ───────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=
# SQLite path for user accounts (orchestrator local auth)
AUTH_DB_PATH=./data/evieai_auth.db
# Default admin seeded on first startup (only if DB is empty)
DEFAULT_ADMIN_EMAIL=admin@evieai.local
DEFAULT_ADMIN_PASSWORD=admin

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated origins. Default: Vite dev server.
CORS_ORIGINS=http://localhost:5173

# ─── File Share ──────────────────────────────────────────────
# Directory the File Share MCP reads from. Default: /tmp/files
LOCAL_SHARE_ROOT=./data/files

# ─── Microsoft Graph (optional — services use demo data without these) ─
# Get these from: terraform output -raw entra_tenant_id / entra_client_id
# The client_secret is in Key Vault (secret name: graph-client-secret)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_USER_ID=

# ─── Teams SSO (optional, feature-flagged) ───────────────────
# ENABLE_TEAMS_SSO=false
# TEAMS_CLIENT_ID=
# TEAMS_CLIENT_SECRET=

# ─── Connectors (Phase 1 scaffold) ────────────────────────────
# Enable Propexo connector registration at startup.
CONNECTOR_PROPEXO_ENABLED=false
# Optional tenant tag attached to registered connector.
# CONNECTOR_DEFAULT_TENANT_ID=
# Propexo API key env var name looked up by runtime.
CONNECTOR_PROPEXO_API_KEY_ENV=PROPEXO_API_KEY
# Default Propexo base URL (override for sandbox/private gateway).
CONNECTOR_PROPEXO_BASE_URL=https://api.propexo.com/v1
# Optional JSON override for multiple connectors/config.
# CONNECTOR_CONFIG_JSON={"connectors":[{"type":"propexo","enabled":true,"api_key_env":"PROPEXO_API_KEY","base_url":"https://api.propexo.com/v1"}]}
# PROPEXO_API_KEY=
# Bitemporal persistence backend: sqlite | postgres
BITEMPORAL_BACKEND=sqlite
# Local SQLite file path (used when BITEMPORAL_BACKEND=sqlite)
BITEMPORAL_DB_PATH=./data/evieai_bitemporal.db
# Postgres DSN (used when BITEMPORAL_BACKEND=postgres)
# BITEMPORAL_POSTGRES_DSN=postgresql://user:pass@localhost:5432/evieai
# Optional fallback if BITEMPORAL_POSTGRES_DSN not set
# DATABASE_URL=postgresql://user:pass@localhost:5432/evieai
# Auto-run Postgres bitemporal migrations at startup
BITEMPORAL_AUTO_MIGRATE=true
# Override migration SQL path if needed
# BITEMPORAL_MIGRATION_SQL_PATH=./db/migrations/0002_bitemporal_runtime_postgres.sql

# Connector sync state store (cursors, dead-letter queue, durable schedule state)
CONNECTOR_SYNC_DB_PATH=./data/evieai_connector_sync.db
# Durable scheduler worker identity (override for multi-instance deployments)
CONNECTOR_SYNC_WORKER_ID=worker-local
# Scheduler poll and lease controls
CONNECTOR_SYNC_POLL_SECONDS=5
CONNECTOR_SYNC_LEASE_SECONDS=60

# Event ingress + signal plumbing
EVENT_SIGNAL_DB_PATH=./data/evieai_event_signal.db
WEBHOOK_SOURCE_SECRET_ENV=WEBHOOK_SHARED_SECRET
WEBHOOK_SHARED_SECRET=

# Safe write-back / actions service
ACTIONS_DB_PATH=./data/evieai_actions.db
# Policy version stamped on decisions/results
ACTIONS_POLICY_VERSION=v1
# Comma-separated risk levels requiring approval queue
ACTIONS_APPROVAL_LEVELS=high
# Optional amount threshold to auto-mark high-risk writes
ACTIONS_HIGH_RISK_AMOUNT=10000

# Sync reliability SLO thresholds
SLO_MAX_SCHEDULE_DUE_LAG_SECONDS=1800
SLO_MAX_FRESHNESS_LAG_SECONDS=3600
SLO_MIN_RUN_SUCCESS_RATE=0.95
SLO_MAX_PENDING_DEAD_LETTERS=20

# Action reliability SLO thresholds
SLO_MIN_ACTION_SUCCESS_RATE=0.95
SLO_MAX_WRITE_FAILURES=5

