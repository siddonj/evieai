# ─── Azure OpenAI (required) ─────────────────────────────────
# Paste values from: terraform output -raw openai_endpoint / openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-openai-name.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ─── Database (local dev defaults are fine) ──────────────────
DB_PASSWORD=DevP@ssw0rd!

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated origins. Default: Vite dev server.
CORS_ORIGINS=http://localhost:5173

# ─── File Share ──────────────────────────────────────────────
# Directory the File Share MCP reads from. Default: /tmp/files
LOCAL_SHARE_ROOT=./data/files

# ─── Microsoft Graph (optional — services use demo data without these) ─
# Get these from: terraform output -raw entra_tenant_id / entra_client_id
# The client_secret is in Key Vault (secret name: graph-client-secret)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_USER_ID=

# ─── Teams SSO (optional, feature-flagged) ───────────────────
# ENABLE_TEAMS_SSO=false
# TEAMS_CLIENT_ID=
# TEAMS_CLIENT_SECRET=
