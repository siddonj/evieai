# ─── Terraform State Bootstrap (One-Time) ─────────────────────────────
# Create backend.hcl from backend.hcl.example and run:
# terraform init -backend-config=backend.hcl

# ─── Deployment ───────────────────────────────────────────────────────
project_name    = "aiqa"
environment     = "dev"
location        = "eastus2"
sql_location    = "centralus"
redis_connection_string = ""
sql_admin_password = "ChangeMe123!"
postgres_admin_password = "ChangeMe123!"
target_user_upn = "user@yourtenant.onmicrosoft.com"

# ─── Scale / Cost ─────────────────────────────────────────────────────
# openai_tpm_capacity         = 10
# container_app_min_replicas  = 0   # scale-to-zero for dev (saves money)
# container_app_max_replicas  = 3
# orchestrator_image_digest   = "sha256:89297011a36540eaf86f5e2b0764d06a5d8b835a45d321e68508df6b0b3a3cf3"

# ─── LLM Provider ─────────────────────────────────────────────────────
# llm_provider = "azure-openai" # switch to "obot-ai" after setting obot vars
# obot_base_url = "https://<your-obot-endpoint>/v1"
# obot_model    = "gpt-4o"
# obot_api_required = false  # only for trusted self-hosted endpoints with no API auth
# obot_api_key  = "<set-in-secret-store-or-pipeline-var>"

# ─── Context Forge Gateway ───────────────────────────────────────────
# context_forge_enabled = true
# context_forge_image = "ghcr.io/ibm/mcp-context-forge:latest"
# context_forge_container_port = 8100
# context_forge_base_url_override = "" # optional manual override
# context_forge_api_key = "<set-in-secret-store-or-pipeline-var>"
# context_forge_timeout_seconds = 10
# context_forge_fallback_mode = "mcp" # mcp | error
# context_forge_cache_enabled = true

# ─── Custom Domain ──────────────────────────────────────────────────────
# ui_custom_domain = "demo.resiq.co"
# api_custom_domain = "api.resiq.co"

# ─── Alerts ──────────────────────────────────────────────────────────
# alert_email = "admin@example.com"  # set to enable Azure Monitor alerting

# ─── Web UI Auth ──────────────────────────────────────────────────────
jwt_secret = "ChangeMeWithARandom32ByteSecret"
# default_admin_email    = "admin@evieai.local"
# default_admin_password = "admin"
